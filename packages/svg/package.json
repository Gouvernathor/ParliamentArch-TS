{
  "name": "@parliamentarch/svg",
  "version": "4.0.0",
  "description": "Tools to generate SVG files of arch-styled parliamentary diagrams",
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },

  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node ../../scripts/clean.ts -d ./dist",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },

  "dependencies": {
    "@parliamentarch/core": "file:../core"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "jsdom": "*"
  },
  "peerDependenciesMeta": {
    "jsdom": {
      "optional": true
    }
  },

  "author": "Gouvernathor",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/Gouvernathor/ParliamentArch-TS.git",
    "directory": "packages/svg"
  },
  "homepage": "https://github.com/Gouvernathor/ParliamentArch-TS#readme",
  "bugs": {
    "url": "https://github.com/Gouvernathor/ParliamentArch-TS/issues"
  },
  "funding": "https://ko-fi.com/gouvernathor",
  "keywords": [
    "parliament",
    "diagram",
    "arch",
    "hemicycle",
    "svg"
  ]
}
